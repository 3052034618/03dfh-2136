{
  "name": "jubensha-table-matcher",
  "version": "1.0.0",
  "description": "剧本杀门店快速凑桌工具",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "node dev-runner.js",
    "dev:vite": "vite",
    "dev:web": "vite --host",
    "build": "tsc && vite build && electron-builder",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "postinstall": "node install-electron.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.15.5",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.jubensha.matcher",
    "productName": "剧本杀快速凑桌助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "剧本杀快速凑桌助手"
    }
  }
}
